# ========== 路径配置 ==========
# # 数据集根目录
# AUDIO_ROOT=/root/autodl-tmp/.autodl/datasets

# # 协议文件路径
# TRAIN_PROTOCOL=/root/autodl-tmp/.autodl/datasets/ASVspoof5_protocols/ASVspoof5.train.tsv
# DEV_PROTOCOL=/root/autodl-tmp/.autodl/datasets/ASVspoof5_protocols/ASVspoof5.dev.track_1.tsv

# # 音频目录
# TRAIN_AUDIO_DIR=/root/autodl-tmp/.autodl/datasets/flac_T
# DEV_AUDIO_DIR=/root/autodl-tmp/.autodl/datasets/flac_D

# # 缓存目录（预处理后的特征存放位置）
# CACHE_DIR=/root/autodl-tmp/.autodl/datasets/cache
# TRAIN_CACHE_DIR=/root/autodl-tmp/.autodl/datasets/cache/flac_T
# DEV_CACHE_DIR=/root/autodl-tmp/.autodl/datasets/cache/flac_D

# 数据集根目录
AUDIO_ROOT=D:/python/VoiceShield/datasets

# 协议文件路径
TRAIN_PROTOCOL=D:/python/VoiceShield/datasets/ASVspoof5_protocols/ASVspoof5.train.tsv
DEV_PROTOCOL=D:/python/VoiceShield/datasets/ASVspoof5_protocols/ASVspoof5.dev.track_1.tsv

# 音频目录
TRAIN_AUDIO_DIR=D:/python/VoiceShield/datasets/flac_T
DEV_AUDIO_DIR=D:/python/VoiceShield/datasets/flac_D

# 缓存目录（预处理后的特征存放位置）
CACHE_DIR=D:/python/VoiceShield/datasets/cache
TRAIN_CACHE_DIR=D:/python/VoiceShield/datasets/cache/flac_T
DEV_CACHE_DIR=D:/python/VoiceShield/datasets/cache/flac_D

# ========== 音频参数 ==========
SR=16000
AUDIO_LENGTH=6

# ========== 预处理参数 ==========
PREPROCESS_BATCH_SIZE=32

# ========== 自编码器训练参数 ==========
AE_BATCH_SIZE=256
AE_NUM_EPOCHS=50
AE_LEARNING_RATE=1e-3
AE_WEIGHT_DECAY=1e-5
AE_PATIENCE=5
AE_LATENT_DIM=128
AE_MAX_SAMPLES=100000
AE_MODEL_PATH=best_autoencoder.pth

# ========== SNN 训练参数 ==========
SNN_BATCH_SIZE=2048
SNN_NUM_EPOCHS=20
SNN_LEARNING_RATE=1e-4
SNN_WEIGHT_DECAY=1e-5
SNN_CLIP_GRAD_NORM=1.0
USE_FOCAL_LOSS=true
FOCAL_ALPHA=0.9
FOCAL_GAMMA=2

# 数据加载
NUM_WORKERS=32

# ========== 其他配置 ==========
SEED=42
HF_ENDPOINT=https://hf-mirror.com
WAV2VEC2_MODEL=facebook/wav2vec2-base